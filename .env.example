# ── Provedor de IA (configure APENAS um) ──

# Google Gemini (grátis, sem cartão de crédito)
# 1M tokens de contexto
# https://aistudio.google.com/apikey
GEMINI_API_KEY=sua-chave-aqui

# DeepSeek (pago, ~$0.14/M tokens)
# https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-sua-chave-aqui

# ── Telegram ──

# Token do bot (crie em @BotFather)
TELEGRAM_TOKEN=1234567890:ABCdefGHIjklmNOPqrstUVwxyz

# Seu User ID numérico (use @userinfobot para descobrir)
# Deixe * para permitir qualquer um (apenas para teste)
TELEGRAM_ALLOW_FROM=*
