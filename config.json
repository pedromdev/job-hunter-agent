{
  "providers": {
    "gemini": {
      "apiKey": "${GEMINI_API_KEY}"
    }
  },
  "modelPresets": {
    "primary": {
      "label": "Gemini",
      "provider": "gemini",
      "model": "gemini-2.5-flash",
      "maxTokens": 8192,
      "contextWindowTokens": 1048576,
      "temperature": 0.3
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "${TELEGRAM_TOKEN}",
      "allowFrom": ["${TELEGRAM_ALLOW_FROM}"]
    },
    "websocket": {
      "enabled": false
    }
  },
  "agents": {
    "defaults": {
      "modelPreset": "primary",
      "provider": "gemini",
      "model": "gemini-2.5-flash",
      "maxTokens": 8192,
      "contextWindowTokens": 1048576,
      "temperature": 0.3,
      "dream": {
        "enabled": true,
        "intervalM": 240
      }
    }
  },
  "tools": {
    "web": {
      "search": { "enabled": true },
      "fetch": { "enabled": true }
    },
    "restrictToWorkspace": false
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790
  }
}
